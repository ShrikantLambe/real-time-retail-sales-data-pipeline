# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control — it is listed in .gitignore.

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=retail_sales

# ── Snowflake ─────────────────────────────────────────────────────────────────
# Account identifier — find it in Snowflake UI under Admin > Accounts
SNOWFLAKE_ACCOUNT=<account_identifier>
# Full hostname used by the Spark connector (sfURL option)
SNOWFLAKE_URL=<account_identifier>.snowflakecomputing.com
SNOWFLAKE_USER=<your_snowflake_user>
SNOWFLAKE_PASSWORD=<your_snowflake_password>
SNOWFLAKE_DATABASE=RETAIL_DB
SNOWFLAKE_SCHEMA=STREAMING
SNOWFLAKE_WAREHOUSE=RETAIL_WH
SNOWFLAKE_ROLE=DATA_ENGINEER

# Airflow Snowflake connection URI — injected automatically, no UI setup needed.
# account/database/schema/warehouse/role are all passed as query parameters.
# Format: snowflake://USER:PASSWORD@/?account=ACCOUNT&database=DB&schema=SCHEMA&warehouse=WH&role=ROLE
AIRFLOW_CONN_SNOWFLAKE_DEFAULT=snowflake://<user>:<password>@/?account=<account_identifier>&database=RETAIL_DB&schema=STREAMING&warehouse=RETAIL_WH&role=DATA_ENGINEER

# ── Airflow ───────────────────────────────────────────────────────────────────
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=<generate_a_new_fernet_key>
DAG_SCHEDULE=*/10 * * * *
SNOWFLAKE_CONN_ID=snowflake_default
DBT_DIR=/opt/airflow/dbt
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# ── Spark ─────────────────────────────────────────────────────────────────────
CHECKPOINT_DIR=/tmp/spark_checkpoint

# ── Postgres (Airflow metadata) ───────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
